# AWS Configuration
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Configuration
DYNAMODB_TABLE_NAME=FamilyCalendar
DYNAMODB_ENDPOINT=http://localhost:8000

# Application Configuration
NODE_ENV=development
PORT=3001

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_EXPIRY_DAYS=30

# Password Hashing
BCRYPT_ROUNDS=12

# OAuth Configuration - Google Calendar
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/google/callback

# OAuth Configuration - Outlook/Microsoft Graph
OUTLOOK_OAUTH_CLIENT_ID=your_outlook_client_id_here
OUTLOOK_OAUTH_CLIENT_SECRET=your_outlook_client_secret_here
OUTLOOK_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/outlook/callback

# Encryption Configuration
ENCRYPTION_KEY=your_encryption_key_here

# Email Notification Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM_ADDRESS=noreply@floapp.com
EMAIL_FROM_NAME=Flo Family Calendar
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY_MS=1000
